<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Book outline - left page -->
    <item android:left="2dp" android:right="13dp"
          android:top="3dp"  android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/>
            <corners android:topLeftRadius="2dp" android:bottomLeftRadius="2dp"/>
        </shape>
    </item>
    <!-- Book outline - right page -->
    <item android:left="13dp" android:right="2dp"
          android:top="3dp"   android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/>
            <corners android:topRightRadius="2dp" android:bottomRightRadius="2dp"/>
        </shape>
    </item>
    <!-- Spine -->
    <item android:left="11dp" android:right="11dp"
          android:top="1dp"   android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>
</layer-list>
