<?xml version="1.0" encoding="utf-8"?>
<!-- Two-tone header background matching the reference app:
     left side golden yellow, right side light blue-grey -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E8F0F7" />
        </shape>
    </item>
    <!-- Golden circle shape on left, clipped by view bounds -->
    <item android:left="-80dp" android:top="-20dp" android:right="200dp" android:bottom="-20dp">
        <shape android:shape="oval">
            <solid android:color="#FFC107" />
        </shape>
    </item>
</layer-list>
