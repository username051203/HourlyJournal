<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#FFFFFF">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingStart="20dp" android:paddingTop="32dp" android:paddingBottom="24dp"
            android:text="Settings" android:textSize="28sp" android:textStyle="bold" android:textColor="#212121" />
        <TextView android:id="@+id/tv_journal_settings"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:paddingStart="20dp" android:gravity="center_vertical"
            android:text="Journal Settings" android:textSize="16sp" android:textColor="#212121"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginStart="20dp" />
        <TextView android:id="@+id/tv_manage_profile"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:paddingStart="20dp" android:gravity="center_vertical"
            android:text="Manage Your Profile" android:textSize="16sp" android:textColor="#212121"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginStart="20dp" />
        <TextView android:id="@+id/tv_manage_tags"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:paddingStart="20dp" android:gravity="center_vertical"
            android:text="Manage Tags" android:textSize="16sp" android:textColor="#212121"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginStart="20dp" />
        <TextView android:id="@+id/tv_export"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:paddingStart="20dp" android:gravity="center_vertical"
            android:text="Export to CSV" android:textSize="16sp" android:textColor="#212121"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginStart="20dp" />
        <TextView android:layout_width="match_parent" android:layout_height="56dp"
            android:paddingStart="20dp" android:gravity="center_vertical"
            android:text="How to use?" android:textSize="16sp" android:textColor="#212121"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginStart="20dp" />
        <TextView android:layout_width="match_parent" android:layout_height="56dp"
            android:paddingStart="20dp" android:gravity="center_vertical"
            android:text="Rate our app" android:textSize="16sp" android:textColor="#212121"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginStart="20dp" />
        <TextView android:layout_width="match_parent" android:layout_height="56dp"
            android:paddingStart="20dp" android:gravity="center_vertical"
            android:text="Share our app" android:textSize="16sp" android:textColor="#212121"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginStart="20dp" />
    </LinearLayout>
</ScrollView>
